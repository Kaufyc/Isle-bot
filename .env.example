DISCORD_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=

# SQLite file path (relative or absolute)
DATABASE_PATH=data/dinos.db
BACKUP_DIR=data/backups
AUTO_BACKUP_MINUTES=30
SAVE_EXPIRATION_HOURS=168
ACTION_COOLDOWN_SECONDS=30

# Optional channels for admin audit and ticket integration
ADMIN_LOG_CHANNEL_ID=
TICKET_CHANNEL_ID=
TICKET_STAFF_ROLE_ID=

# RCON (required for restore command)
RCON_HOST=127.0.0.1
RCON_PORT=7778
RCON_PASSWORD=your_rcon_password
RCON_TIMEOUT=8

# Pterodactyl (optional but supported)
PTERODACTYL_PANEL_URL=https://panel.example.com
PTERODACTYL_API_KEY=ptlc_xxxxxxxxxxxxxxxxxx
PTERODACTYL_SERVER_IDENTIFIER=abcd1234

# Multi-server / cluster support (optional).
# If provided, this overrides single RCON_HOST/RCON_PORT/RCON_PASSWORD values.
# Use a single-line JSON array in production.
SERVERS_JSON=[{"id":"eu1","cluster":"cluster-a","host":"127.0.0.1","port":7778,"password":"pw1","timeout":8,"pterodactyl_server_identifier":"srv_eu1"},{"id":"us1","cluster":"cluster-a","host":"127.0.0.1","port":7788,"password":"pw2","timeout":8,"pterodactyl_server_identifier":"srv_us1"}]

# Command templates sent over RCON.
# RESTORE placeholders: {user_id}, {slot}, {steam_id}, {name}, {species}, {growth}, {location}, {server_id}, {cluster_id}, {live_data}
RESTORE_COMMAND_TEMPLATE=restore_dino {steam_id} "{species}" {growth} "{location}" {server_id} {cluster_id}

# ADMIN recreate placeholders: {target_user_id}, {admin_user_id}, {slot}, {steam_id}, {name}, {species}, {growth}, {location}, {server_id}, {cluster_id}
ADMIN_RECREATE_COMMAND_TEMPLATE=admin_recreate {target_user_id} {steam_id} "{species}" {growth} "{location}"

# Player data and online verification commands
ONLINE_PLAYERS_COMMAND=listplayers
PLAYER_DINO_QUERY_TEMPLATE=player_dino {steam_id}
KILL_CHARACTER_COMMAND_TEMPLATE=kill_player_dino {steam_id}
